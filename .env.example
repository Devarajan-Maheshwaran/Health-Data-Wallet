# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Deployer wallet private key (without 0x prefix is fine)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# BscScan API key for contract verification
# Get one free at: https://bscscan.com/myapikey
BSCSCAN_API_KEY=your_bscscan_api_key_here

# BNB Greenfield (filled in by frontend .env.local, not needed for contract deployment)
NEXT_PUBLIC_GREENFIELD_RPC=https://gnfd-testnet-fullnode-tendermint-ap.bnbchain.org
NEXT_PUBLIC_GREENFIELD_CHAIN_ID=5600
NEXT_PUBLIC_SP_ADDRESS=your_storage_provider_address

# Supabase (backend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Upstash Redis (rate limiting + notification queue)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# Contract addresses (filled after deployment)
NEXT_PUBLIC_PATIENT_REGISTRY_ADDRESS=
NEXT_PUBLIC_HEALTH_RECORD_STORE_ADDRESS=
NEXT_PUBLIC_ACCESS_CONTROLLER_ADDRESS=
