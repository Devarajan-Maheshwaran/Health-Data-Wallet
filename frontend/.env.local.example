# Copy to .env.local and fill in

# --- Wallet / Chain ---
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# --- Contract Addresses (BSC Testnet) ---
NEXT_PUBLIC_PATIENT_REGISTRY_ADDRESS=
NEXT_PUBLIC_HEALTH_RECORD_STORE_ADDRESS=
NEXT_PUBLIC_ACCESS_CONTROLLER_ADDRESS=
NEXT_PUBLIC_CHAIN_ID=97

# --- BNB Greenfield ---
NEXT_PUBLIC_GREENFIELD_RPC=https://gnfd-testnet-fullnode-tendermint-ap.bnbchain.org
NEXT_PUBLIC_GREENFIELD_CHAIN_ID=5600
NEXT_PUBLIC_SP_ADDRESS=your_storage_provider_address

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Upstash Redis ---
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
