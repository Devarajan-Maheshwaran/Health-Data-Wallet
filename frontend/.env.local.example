# ============================================================
# MedVault Frontend — Environment Variables
# Copy to .env.local and fill in values. Never commit .env.local
# ============================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WalletConnect Project ID (get free at cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# BNB Greenfield
NEXT_PUBLIC_GREENFIELD_RPC=https://gnfd-testnet-fullnode-tendermint-ap.bnbchain.org
NEXT_PUBLIC_GREENFIELD_CHAIN_ID=5600
NEXT_PUBLIC_SP_ADDRESS=your_storage_provider_address

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Smart contract addresses (fill after deployment)
NEXT_PUBLIC_PATIENT_REGISTRY_ADDRESS=
NEXT_PUBLIC_HEALTH_RECORD_STORE_ADDRESS=
NEXT_PUBLIC_ACCESS_CONTROLLER_ADDRESS=

# Upstash Redis (optional: rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
